{
  "name": "turbo-ui",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "gen:theme": "node scripts/gen-theme-css.cjs",
    "prebuild": "npm run gen:theme",
    "prebuild-storybook": "npm run gen:theme",
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build -c vite.config.lib.js && node scripts/copy-styles.cjs",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/ui/button.d.ts",
      "import": "./dist/ui/button.js"
    },
    "./icon-button": {
      "types": "./dist/ui/icon-button.d.ts",
      "import": "./dist/ui/icon-button.js"
    },
    "./link": {
      "types": "./dist/ui/link.d.ts",
      "import": "./dist/ui/link.js"
    },
    "./input": {
      "types": "./dist/ui/input.d.ts",
      "import": "./dist/ui/input.js"
    },
    "./input-field": {
      "types": "./dist/ui/input-field.d.ts",
      "import": "./dist/ui/input-field.js"
    },
    "./floating-input-field": {
      "types": "./dist/ui/floating-input-field.d.ts",
      "import": "./dist/ui/floating-input-field.js"
    },
    "./textarea": {
      "types": "./dist/ui/textarea.d.ts",
      "import": "./dist/ui/textarea.js"
    },
    "./checkbox": {
      "types": "./dist/ui/checkbox.d.ts",
      "import": "./dist/ui/checkbox.js"
    },
    "./radio": {
      "types": "./dist/ui/radio.d.ts",
      "import": "./dist/ui/radio.js"
    },
    "./toggle": {
      "types": "./dist/ui/toggle.d.ts",
      "import": "./dist/ui/toggle.js"
    },
    "./tabs": {
      "types": "./dist/ui/tabs.d.ts",
      "import": "./dist/ui/tabs.js"
    },
    "./listbox": {
      "types": "./dist/ui/listbox.d.ts",
      "import": "./dist/ui/listbox.js"
    },
    "./select": {
      "types": "./dist/ui/select.d.ts",
      "import": "./dist/ui/select.js"
    },
    "./select-field": {
      "types": "./dist/ui/select-field.d.ts",
      "import": "./dist/ui/select-field.js"
    },
    "./combobox": {
      "types": "./dist/ui/combobox.d.ts",
      "import": "./dist/ui/combobox.js"
    },
    "./combobox-field": {
      "types": "./dist/ui/combobox-field.d.ts",
      "import": "./dist/ui/combobox-field.js"
    },
    "./textarea-field": {
      "types": "./dist/ui/textarea-field.d.ts",
      "import": "./dist/ui/textarea-field.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    },
    "./styles/theme": "./dist/styles/theme.css",
    "./styles/theme-vars": "./dist/styles/theme-vars.css",
    "./styles/fonts": "./dist/styles/fonts.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@floating-ui/react": "^0.27.19",
    "@storybook/addon-a11y": "^10.1.8",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/addon-onboarding": "^10.1.8",
    "@storybook/addon-vitest": "^10.1.8",
    "@storybook/react-vite": "^10.1.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.562.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-syntax-highlighter": "^16.1.0",
    "storybook": "^10.1.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15"
  }
}
